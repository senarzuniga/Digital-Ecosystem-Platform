# ── App settings ───────────────────────────────────────────────────────────────
APP_NAME="Digital Ecosystem Platform"
DEBUG=false

# ── Security — CHANGE IN PRODUCTION ──────────────────────────────────────────
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./dep_platform.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://dep:dep_secret@localhost:5432/dep_platform

POSTGRES_USER=dep
POSTGRES_PASSWORD=dep_secret
POSTGRES_DB=dep_platform

# ── Event Bus ─────────────────────────────────────────────────────────────────
EVENT_BUS_BACKEND=memory
# Set to "redis" to enable Redis pub/sub:
# EVENT_BUS_BACKEND=redis
REDIS_URL=redis://localhost:6379

# ── MQTT (IIoT) ───────────────────────────────────────────────────────────────
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── OPC-UA ────────────────────────────────────────────────────────────────────
OPCUA_ENABLED=false
OPCUA_ENDPOINT=opc.tcp://localhost:4840

# ── External source (Factory Simulator) ───────────────────────────────────────
FACTORY_SIMULATOR_URL=http://localhost:9100

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Streamlit frontend ────────────────────────────────────────────────────────
DEP_BACKEND_URL=http://localhost:8000
